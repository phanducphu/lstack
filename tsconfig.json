{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./src/types/*"],
      "@main/*": ["./main/*"]
    }
  },
  "include": ["main/**/*", "src/**/*", "vite*.ts", "forge.config.ts"],
  "exclude": ["node_modules", "dist", ".vite"]
}
