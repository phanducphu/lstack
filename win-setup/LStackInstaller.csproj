<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>icon.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>LStack Setup</AssemblyName>
    <RootNamespace>LStackInstaller</RootNamespace>
    <Version>1.0.0</Version>
    <Company>Marix</Company>
    <Product>LStack Installer</Product>
    <Description>Installer for LStack - Local Development Stack</Description>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\icon.png" />
  </ItemGroup>

  <!-- payload.zip is generated by the build script and embedded at compile time -->
  <ItemGroup Condition="Exists('payload.zip')">
    <EmbeddedResource Include="payload.zip" LogicalName="LStackInstaller.payload.zip" />
  </ItemGroup>

</Project>
