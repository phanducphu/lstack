<Window x:Class="LStackInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Title="LStack Setup"
        Width="720" Height="440"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif">

    <Border Margin="14" CornerRadius="0" ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush Color="#0a0f1c"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="36" Opacity="0.75" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="252"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 
                 LEFT  BRAND PANEL
             -->
            <Grid Grid.Column="0" ClipToBounds="True">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0.4,0" EndPoint="0.6,1">
                        <GradientStop Color="#050c17" Offset="0"/>
                        <GradientStop Color="#091525" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- Blue atmospheric glow (top area) -->
                <Ellipse Width="280" Height="220"
                         HorizontalAlignment="Center" VerticalAlignment="Top"
                         Margin="0,-30,0,0"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#1f2463eb" Offset="0"/>
                            <GradientStop Color="#002463eb" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Diagonal accent lines (subtle) -->
                <Canvas Width="252" Height="412" IsHitTestVisible="False" ClipToBounds="True" Opacity="0.35">
                    <Line X1="280" Y1="0" X2="-10" Y2="410" Stroke="#0d2040" StrokeThickness="1"/>
                    <Line X1="320" Y1="0" X2="30"  Y2="410" Stroke="#0a1830" StrokeThickness="1"/>
                    <Line X1="360" Y1="0" X2="70"  Y2="410" Stroke="#08152a" StrokeThickness="1"/>
                </Canvas>

                <!-- Content rows -->
                <Grid Margin="28,30,24,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Icon + App name block -->
                    <StackPanel Grid.Row="0">
                        <Image Source="pack://application:,,,/Assets/icon.png"
                               Width="52" Height="52"
                               HorizontalAlignment="Left"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="0,0,0,14"/>
                        <TextBlock Text="LStack"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#e8eaf6"
                                   Margin="0,0,0,3"/>
                        <TextBlock Text="Local Development Stack"
                                   FontSize="11"
                                   Foreground="#c0cce0"/>
                    </StackPanel>

                    <!-- Separator -->
                    <Rectangle Grid.Row="2" Height="1" Fill="#0d1e33"/>

                    <!-- Feature list -->
                    <StackPanel Grid.Row="4">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,11">
                            <Ellipse Width="5" Height="5" Fill="#2463eb"
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="FeatureLine1" FontSize="11" Foreground="#dde4f4"
                                       Text="Nginx  ·  Apache  ·  PHP-FPM"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,11">
                            <Ellipse Width="5" Height="5" Fill="#2463eb"
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="FeatureLine2" FontSize="11" Foreground="#dde4f4"
                                       Text="MariaDB  ·  Redis  ·  Mailpit"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Ellipse Width="5" Height="5" Fill="#2463eb"
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="FeatureLine3" FontSize="11" Foreground="#dde4f4"
                                       Text="PHP profiles  ·  Virtual hosts  ·  SSL"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- Version badge (bottom) -->
                    <Border Grid.Row="6" HorizontalAlignment="Left"
                            Background="#0d1a2e" CornerRadius="4"
                            BorderBrush="#1a2d44" BorderThickness="1"
                            Padding="8,3">
                        <TextBlock Text="v1.0.0"
                                   FontSize="10" Foreground="#8899bb"/>
                    </Border>

                </Grid>
            </Grid>

            <!-- Divider line -->
            <Rectangle Grid.Column="0" Width="1"
                        HorizontalAlignment="Right" Fill="#0c1a2e"/>

            <!-- 
                 RIGHT  CONTROL PANEL
             -->
            <Grid Grid.Column="1" Background="#0a0f1c">

                <!-- Window chrome -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Panel.ZIndex="10">
                    <Button Content="&#x2212;" Click="MinimizeButton_Click"
                            Style="{StaticResource ChromeButton}" FontSize="16"/>
                    <Button Content="&#x2715;" Click="CloseButton_Click"
                            Style="{StaticResource CloseButton}" FontSize="12"/>
                </StackPanel>

                <!--  LANGUAGE PAGE  -->
                <StackPanel x:Name="LanguagePage" VerticalAlignment="Center" Margin="44,0,40,0">

                    <TextBlock Text="Choose language"
                               FontSize="10" FontWeight="Medium" Foreground="#8899bb"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Chọn ngôn ngữ cài đặt"
                               FontSize="19" FontWeight="SemiBold" Foreground="#ffffff"
                               Margin="0,0,0,36"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- English card -->
                        <Button Grid.Column="0" Click="LangEN_Click" Cursor="Hand"
                                Height="90" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#0d1827"
                                            BorderBrush="#1a2d44" BorderThickness="1">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="EN" FontSize="26" FontWeight="Bold"
                                                       Foreground="#ffffff" HorizontalAlignment="Center"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="English" FontSize="11"
                                                       Foreground="#8899bb" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="BorderBrush" Value="#2463eb"/>
                                            <Setter TargetName="bg" Property="Background" Value="#111e33"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#0e1a2e"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Vietnamese card -->
                        <Button Grid.Column="2" Click="LangVI_Click" Cursor="Hand"
                                Height="90" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#0d1827"
                                            BorderBrush="#1a2d44" BorderThickness="1">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="VI" FontSize="26" FontWeight="Bold"
                                                       Foreground="#ffffff" HorizontalAlignment="Center"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Tiếng Việt" FontSize="11"
                                                       Foreground="#8899bb" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="BorderBrush" Value="#2463eb"/>
                                            <Setter TargetName="bg" Property="Background" Value="#111e33"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#0e1a2e"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </Grid>
                </StackPanel>

                <!--  SETUP PAGE  -->
                <StackPanel x:Name="SetupPage" VerticalAlignment="Center" Margin="44,0,40,0" Visibility="Collapsed">

                    <TextBlock x:Name="TxtSetupTitle" Text="Get started"
                               FontSize="19" FontWeight="SemiBold"
                               Foreground="#ffffff" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtSetupSub" Text="Choose where to install LStack."
                               FontSize="12" Foreground="#c0cce0"
                               Margin="0,0,0,28"/>

                    <!-- Install path label (uppercase) -->
                    <TextBlock x:Name="TxtInstallLocation" Text="INSTALL LOCATION"
                               FontSize="10" FontWeight="Medium"
                               Foreground="#8899bb"
                               Margin="0,0,0,8"/>

                    <Grid Height="38" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="78"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InstallPathBox"
                                 Grid.Column="0"
                                 Text="C:\LStack"
                                 Style="{StaticResource DarkTextBox}"/>
                        <Button x:Name="BtnBrowse" Grid.Column="2"
                                Content="Browse"
                                Click="Browse_Click"
                                Style="{StaticResource SecondaryButton}"/>
                    </Grid>

                    <CheckBox x:Name="DesktopShortcutCheck"
                              Content="Create Desktop shortcut"
                              IsChecked="True"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,0,0,10"/>
                    <CheckBox x:Name="StartMenuCheck"
                              Content="Add to Start Menu"
                              IsChecked="True"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,0,0,30"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnInstall" Grid.Column="0"
                                Content="Install"
                                Click="Install_Click"
                                Style="{StaticResource PrimaryButton}"/>
                        <Button x:Name="BtnCancel" Grid.Column="2"
                                Content="Cancel"
                                Click="Cancel_Click"
                                Style="{StaticResource SecondaryButton}"
                                Height="42"
                                HorizontalAlignment="Stretch"
                                FontSize="13" FontWeight="SemiBold"
                                Foreground="#aabbd4"/></Grid>

                </StackPanel>

                <!--  INSTALLING PAGE  -->
                <StackPanel x:Name="InstallingPage" VerticalAlignment="Center"
                            Margin="44,0,40,0" Visibility="Collapsed">

                    <TextBlock x:Name="TxtInstallingTitle" Text="Installing LStack"
                               FontSize="19" FontWeight="SemiBold"
                               Foreground="#ffffff" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtInstallingSub" Text="Please keep this window open."
                               FontSize="12" Foreground="#c0cce0"
                               Margin="0,0,0,36"/>

                    <!-- Large percentage indicator -->
                    <TextBlock x:Name="ProgressText"
                               Text="0%"
                               FontSize="44" FontWeight="Bold"
                               Foreground="#2463eb"
                               Margin="0,0,0,14"/>

                    <!-- Thin progress track -->
                    <ProgressBar x:Name="InstallProgress"
                                 Value="0" Maximum="100"
                                 Style="{StaticResource RoundedProgressBar}"
                                 Margin="0,0,0,14"/>

                    <TextBlock x:Name="StatusText"
                               Text="Preparing"
                               FontSize="11" Foreground="#c0cce0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="FileCountText"
                               Text=""
                               FontSize="10" Foreground="#8899bb"
                               Margin="0,4,0,0"/>

                </StackPanel>

                <!--  COMPLETE PAGE  -->
                <StackPanel x:Name="CompletePage" VerticalAlignment="Center"
                            Margin="44,0,40,0" Visibility="Collapsed">

                    <!-- Small checkmark -->
                    <Grid Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,22">
                        <Ellipse Fill="#0e1e3a"/>
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="20" Height="20">
                                <Path Data="M 1,10 L 7,17 L 19,3"
                                      Stroke="#2463eb" StrokeThickness="2.3"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <TextBlock x:Name="TxtAllSet" Text="All set!"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#ffffff" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtCompleteSub" Text="LStack is installed and ready to use."
                               FontSize="12" Foreground="#c0cce0"
                               Margin="0,0,0,28"/>

                    <CheckBox x:Name="LaunchCheck"
                              Content="Launch LStack now"
                              IsChecked="True"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,0,0,24"/>

                    <Button x:Name="BtnFinish" Content="Finish"
                            Click="Finish_Click"
                            Style="{StaticResource PrimaryButton}"/>

                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>